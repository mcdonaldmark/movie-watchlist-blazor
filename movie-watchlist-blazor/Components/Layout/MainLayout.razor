@inherits LayoutComponentBase
@inject NavigationManager NavManager
@inject movie_watchlist_blazor.Services.AppState AppState

<div class="app-shell">

    @if (ShowSidebar)
    {
        <div class="sidebar">

            <h4 class="brand">🎬 Movie App</h4>

            <div class="brand-spacing"></div>

            <nav class="nav-links">

                <NavLink href="/dashboard" class="nav-link">
                    🏠 Dashboard
                </NavLink>

                <NavLink href="/movies" class="nav-link">
                    🎥 Movies
                </NavLink>

                <NavLink href="/logout" class="nav-link">
                    🚪 Logout
                </NavLink>

            </nav>

        </div>
    }

    <div class="main-content">
        @Body
    </div>

</div>

@code {

    private bool ShowSidebar => !IsAuthPage();

    private bool IsAuthPage()
    {
        var uri = NavManager.ToBaseRelativePath(NavManager.Uri).ToLower();

        return uri == ""
            || uri == "login"
            || uri == "register"
            || uri == "home";
    }
}