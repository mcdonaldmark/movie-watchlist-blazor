@page "/register"
@rendermode InteractiveServer

@using movie_watchlist_blazor.Models
@using movie_watchlist_blazor.Data
@using System.Linq

@inject NavigationManager NavManager
@inject ApplicationDbContext Db

<div class="page-center">
    <div class="auth-card">

        <h2>Register</h2>

        <input class="form-control mb-2" placeholder="Name" @bind="name" />
        <input class="form-control mb-2" placeholder="Email" @bind="email" />

        <!-- FIX: added placeholder -->
        <input class="form-control mb-3" type="password" placeholder="Password" @bind="password" />

        <button class="btn btn-primary w-100" @onclick="CreateAccount">
            Create Account
        </button>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="text-danger mt-2">@errorMessage</div>
        }

        <p class="mt-3 text-muted">
            Already have an account?
            <a href="/login">Login!</a>
        </p>

        <p class="mt-2">
            <a href="/">← Return to Home Screen</a>
        </p>

    </div>
</div>

@code {
    private string name = "";
    private string email = "";
    private string password = "";
    private string errorMessage = "";

    private async Task CreateAccount()
    {
        errorMessage = "";

        // ✅ REQUIRED FIELD CHECK (NEW)
        if (string.IsNullOrWhiteSpace(name) ||
            string.IsNullOrWhiteSpace(email) ||
            string.IsNullOrWhiteSpace(password))
        {
            errorMessage = "All fields are required (Name, Email, Password).";
            return;
        }

        var exists = Db.Users.Any(u => u.Email == email);

        if (exists)
        {
            errorMessage = "Email already exists.";
            return;
        }

        var user = new AppUser
        {
            Name = name,
            Email = email,
            Password = password
        };

        Db.Users.Add(user);
        await Db.SaveChangesAsync();

        NavManager.NavigateTo("/login");
    }
}