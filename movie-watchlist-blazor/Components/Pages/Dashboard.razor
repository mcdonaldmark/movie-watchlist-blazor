@page "/dashboard"
@using movie_watchlist_blazor.Models
@using movie_watchlist_blazor.Services
@inject NavigationManager NavManager

<div class="dashboard-wrapper">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="mb-1">🎬 My Movie Dashboard</h1>
            <p class="text-muted mb-0">
                Track, rate, and manage your watchlist
            </p>
        </div>

        <button type="button" class="btn btn-primary" @onclick="GoToMovies">
            + Add Movie
        </button>
    </div>

    <!-- FILTER BAR -->
    <div class="row mb-4">
        <div class="col-md-6 mb-2">
            <input class="form-control" placeholder="Search movies..." @bind="searchText" />
        </div>

        <div class="col-md-3 mb-2">
            <select class="form-select" @bind="selectedGenre">
                <option value="">All Genres</option>
                <option>Action</option>
                <option>Drama</option>
                <option>Sci-Fi</option>
                <option>Comedy</option>
                <option>Horror</option>
            </select>
        </div>
    </div>

    <!-- STATS -->
    <div class="row mb-4">

        <div class="col-md-6 mb-2">
            <div class="card p-3 text-center">
                <h6>🎬 Total Movies</h6>
                <h3>@MovieState.Movies.Count</h3>
            </div>
        </div>

        <div class="col-md-6 mb-2">
            <div class="card p-3 text-center">
                <h6>📊 Watched Status</h6>
                <h3>@MovieState.WatchedMovieIds.Count / @MovieState.Movies.Count Watched</h3>
            </div>
        </div>

    </div>

    <!-- MOVIE GRID -->
    <div class="row">

        @foreach (var movie in FilteredMovies)
        {
            <div class="col-md-4 mb-3">

                <div class="card h-100 p-3">

                    <h5 class="mb-1">@movie.Title</h5>

                    <small class="text-muted">
                        @movie.Genre • @movie.Year
                    </small>

                    <!-- STAR RATING -->
                    <div class="mt-2 mb-2">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <span>
                                @(i <= Math.Round(movie.AverageRating) ? "⭐" : "☆")
                            </span>
                        }
                    </div>

                    <!-- WATCHED BADGE -->
                    @if (MovieState.WatchedMovieIds.Contains(movie.Id))
                    {
                        <span class="badge bg-success">Watched</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Not Watched</span>
                    }

                    <!-- ACTION -->
                    <div class="mt-2">
                        <button class="btn btn-sm btn-success w-100" @onclick="() => ToggleWatched(movie.Id)">
                            @(MovieState.WatchedMovieIds.Contains(movie.Id) ? "Unwatch" : "Mark Watched")
                        </button>
                    </div>

                </div>

            </div>
        }

    </div>

</div>

@code {

    private string searchText = "";
    private string selectedGenre = "";

    private IEnumerable<MovieDto> FilteredMovies =>
        MovieState.Movies.Where(m =>
            (string.IsNullOrWhiteSpace(searchText) ||
             m.Title.Contains(searchText, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrWhiteSpace(selectedGenre) ||
             m.Genre == selectedGenre)
        );

    private void ToggleWatched(int id)
    {
        if (MovieState.WatchedMovieIds.Contains(id))
        {
            MovieState.WatchedMovieIds.Remove(id);
        }
        else
        {
            MovieState.WatchedMovieIds.Add(id);
        }
    }

    private void GoToMovies()
    {
        NavManager.NavigateTo("/movies");
    }
}