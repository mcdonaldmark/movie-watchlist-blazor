@page "/dashboard"
@using movie_watchlist_blazor.Models

<div class="dashboard-wrapper">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="mb-1">🎬 My Movie Dashboard</h1>
            <p class="text-muted mb-0">
                Track, rate, and manage your watchlist
            </p>
        </div>

        <button class="btn btn-primary">
            + Add Movie
        </button>
    </div>

    <!-- FILTER BAR -->
    <div class="row mb-4">
        <div class="col-md-6 mb-2">
            <input class="form-control" placeholder="Search movies..." @bind="searchText" />
        </div>

        <div class="col-md-3 mb-2">
            <select class="form-select" @bind="selectedGenre">
                <option value="">All Genres</option>
                <option>Action</option>
                <option>Drama</option>
                <option>Sci-Fi</option>
                <option>Comedy</option>
                <option>Horror</option>
            </select>
        </div>
    </div>

    <!-- STATS -->
    <div class="row mb-4">
        <div class="col-md-4 mb-2">
            <div class="card p-3 text-center">
                <h6>🎥 Watchlist</h6>
                <h3>@WatchlistCount</h3>
            </div>
        </div>

        <div class="col-md-4 mb-2">
            <div class="card p-3 text-center">
                <h6>✅ Watched</h6>
                <h3>@WatchedCount</h3>
            </div>
        </div>

        <div class="col-md-4 mb-2">
            <div class="card p-3 text-center">
                <h6>⭐ Avg Rating</h6>
                <h3>@AverageRating.ToString("0.0")</h3>
            </div>
        </div>
    </div>

    <!-- MOVIE GRID -->
    <div class="row">

        @foreach (var movie in FilteredMovies)
        {
            <div class="col-md-4 mb-3">

                <div class="card h-100 p-3">

                    <h5 class="mb-1">@movie.Title</h5>

                    <small class="text-muted">@movie.Genre</small>

                    <p class="mt-2 mb-2">
                        @movie.Description
                    </p>

                    <!-- STAR RATING -->
                    <div class="mb-2">
                        @for (int i = 1; i <= 5; i++)
                        {
                            if (i <= movie.Rating)
                            {
                                <span>⭐</span>
                            }
                            else
                            {
                                <span class="text-muted">☆</span>
                            }
                        }
                    </div>

                    <!-- STATUS -->
                    @if (movie.IsWatched)
                    {
                        <span class="badge bg-success mb-2">Watched</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark mb-2">Watchlist</span>
                    }

                    <!-- ACTIONS -->
                    <div class="d-flex gap-2 mt-2">
                        <button class="btn btn-sm btn-outline-primary w-100">
                            Edit
                        </button>

                        <button class="btn btn-sm btn-outline-danger w-100">
                            Delete
                        </button>

                        <button class="btn btn-sm btn-outline-success w-100">
                            @(movie.IsWatched ? "Unwatch" : "Watched")
                        </button>
                    </div>

                </div>
            </div>
        }

    </div>
</div>

@code {

    private string searchText = "";
    private string selectedGenre = "";

    private List<Movie> movies = new()
    {
        new Movie { Title = "Inception", Genre = "Sci-Fi", Description = "Dream heist thriller", Rating = 5, IsWatched = true },
        new Movie { Title = "Interstellar", Genre = "Sci-Fi", Description = "Space exploration and time", Rating = 5, IsWatched
= false },
        new Movie { Title = "The Dark Knight", Genre = "Action", Description = "Batman vs Joker", Rating = 5, IsWatched = true
},
        new Movie { Title = "Toy Story", Genre = "Comedy", Description = "Animated classic", Rating = 4, IsWatched = false }
    };

    private IEnumerable<Movie> FilteredMovies =>
        movies.Where(m =>
            (string.IsNullOrWhiteSpace(searchText) ||
             m.Title.Contains(searchText, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrWhiteSpace(selectedGenre) ||
             m.Genre == selectedGenre)
        );

    private int WatchlistCount => movies.Count(m => !m.IsWatched);
    private int WatchedCount => movies.Count(m => m.IsWatched);

    private double AverageRating =>
        movies.Count == 0 ? 0 : movies.Average(m => m.Rating);
}