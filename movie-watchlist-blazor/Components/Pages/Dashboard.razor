@page "/dashboard"
@using movie_watchlist_blazor.Models
@using movie_watchlist_blazor.Services
@inject NavigationManager NavManager
@inject AppState AppState
@rendermode InteractiveServer

<div class="dashboard-wrapper">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="mb-1">🎬 My Movie Dashboard</h1>

            <!-- FIX: only show welcome line if we actually have a user -->
            @if (!string.IsNullOrWhiteSpace(AppState.CurrentUserName))
            {
                <p class="text-muted mb-0">
                    Welcome, <strong>@AppState.CurrentUserName</strong>.
                </p>
            }

            <p class="text-muted mb-0">
                Track, rate, and manage your watchlist
            </p>
        </div>

        <button type="button" class="btn btn-primary" @onclick="GoToMovies">
            + Add Movie
        </button>
    </div>

    <div class="row mb-4">
        <div class="col-md-6 mb-2">
            <input class="form-control" placeholder="Search movies..." @bind="searchText" />
        </div>

        <div class="col-md-3 mb-2">
            <select class="form-select" @bind="selectedGenre">
                <option value="">All Genres</option>
                <option>Action</option>
                <option>Drama</option>
                <option>Sci-Fi</option>
                <option>Comedy</option>
                <option>Horror</option>
            </select>
        </div>
    </div>

    <!-- DASHBOARD STATS -->
    <div class="row mb-4">

        <div class="col-md-6 mb-2">
            <div class="card p-3 text-center">
                <h6>🎬 Total Movies</h6>
                <h3>—</h3>
            </div>
        </div>

        <div class="col-md-6 mb-2">
            <div class="card p-3 text-center">
                <h6>📊 Watched Status</h6>
                <h3>— / — Watched</h3>
            </div>
        </div>

    </div>

</div>

@code {

    private string searchText = "";
    private string selectedGenre = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // IMPORTANT: safe place to trigger JS-backed loading chain
            await AppState.LoadUserAsync();

            // ensures UI updates after sessionStorage load
            StateHasChanged();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await AppState.LoadUserAsync();
    }

    private void GoToMovies()
    {
        NavManager.NavigateTo("/movies");
    }
}