@page "/movies"
@using movie_watchlist_blazor.Models
@using movie_watchlist_blazor.Services
@inject NavigationManager NavManager

<div class="page-center movies-page">
    <div class="dashboard-wrapper w-100">

        <h1 class="mb-5 text-center movie-page-title">🎬 Movies</h1>

        @if (MovieState.Movies == null)
        {
            <p class="text-center">Loading movies...</p>
        }
        else
        {
            <div class="row justify-content-center">

                @foreach (var movie in MovieState.Movies)
                {
                    <div class="col-md-6 mb-3">

                        <div class="card p-3 shadow-sm">

                            <h5 style="cursor:pointer;" @onclick="() => GoToMovie(movie.Id)">
                                @movie.Title
                            </h5>

                            <p class="text-muted">@movie.Genre • @movie.Year</p>

                            <!-- STARS -->
                            <div class="mb-2">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <span>
                                        @(i <= Math.Round(movie.AverageRating) ? "⭐" : "☆")
                                    </span>
                                }
                            </div>

                            <!-- WATCHED STATUS -->
                            @if (MovieState.IsWatched(movie.Id))
                            {
                                <span class="badge bg-success mb-2">Watched</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark mb-2">Not Watched</span>
                            }

                            <!-- ACTIONS -->
                            <div class="d-flex gap-2 mt-2">

                                <button class="btn btn-sm btn-success w-100" @onclick="() => ToggleWatched(movie.Id)">
                                    @(MovieState.IsWatched(movie.Id) ? "Unwatch" : "Watch")
                                </button>

                                <button class="btn btn-sm btn-primary w-100" @onclick="() => GoToReviews(movie.Id)">
                                    Reviews
                                </button>

                                <button class="btn btn-sm btn-dashboard w-100" @onclick="() => AddToDashboard(movie.Id)">
                                    Add to Dashboard
                                </button>

                            </div>

                            @if (addedMovieId == movie.Id)
                            {
                                <div class="mt-2 text-success fw-bold">
                                    Added successfully ✅
                                </div>
                            }

                        </div>

                    </div>
                }

            </div>
        }

    </div>
</div>

@code {

    private int? addedMovieId;

    private void ToggleWatched(int id)
    {
        MovieState.ToggleWatched(id);
    }

    private void AddToDashboard(int id)
    {
        MovieState.ToggleWatched(id);

        addedMovieId = id;

        _ = Task.Run(async () =>
        {
            await Task.Delay(2000);
            addedMovieId = null;
            await InvokeAsync(StateHasChanged);
        });
    }

    private void GoToReviews(int movieId)
    {
        NavManager.NavigateTo($"/reviews/{movieId}");
    }

    private void GoToMovie(int movieId)
    {
        NavManager.NavigateTo($"/movie/{movieId}");
    }
}