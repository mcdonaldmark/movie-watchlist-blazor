@page "/movies"
@using movie_watchlist_blazor.Models
@using movie_watchlist_blazor.Services
@inject NavigationManager NavManager

<div class="page-center">
    <div class="dashboard-wrapper w-100">

        <h3 class="mb-4 text-center">🎬 Movies</h3>

        @if (MovieState.Movies == null)
        {
            <p class="text-center">Loading movies...</p>
        }
        else
        {
            <div class="row justify-content-center">

                @foreach (var movie in MovieState.Movies)
                {
                    <div class="col-md-6 mb-3">

                        <div class="card p-3 shadow-sm">

                            <!-- CLICKABLE TITLE (NEW) -->
                            <h5 style="cursor:pointer;" @onclick="() => GoToMovie(movie.Id)">
                                @movie.Title
                            </h5>

                            <p class="text-muted">@movie.Genre • @movie.Year</p>

                            <!-- STAR RATING -->
                            <div class="mb-2">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <span>
                                        @(i <= Math.Round(movie.AverageRating) ? "⭐" : "☆")
                                    </span>
                                }
                            </div>

                            <!-- WATCHED STATUS -->
                            @if (MovieState.WatchedMovieIds.Contains(movie.Id))
                            {
                                <span class="badge bg-success mb-2">Watched</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark mb-2">Not Watched</span>
                            }

                            <!-- ACTIONS -->
                            <div class="d-flex gap-2 mt-2">

                                <button class="btn btn-success btn-sm w-100" @onclick="() => ToggleWatched(movie.Id)">
                                    @(MovieState.WatchedMovieIds.Contains(movie.Id) ? "Unwatch" : "Watch")
                                </button>

                                <button class="btn btn-primary btn-sm w-100" @onclick="() => GoToReviews(movie.Id)">
                                    Reviews
                                </button>

                            </div>

                        </div>

                    </div>
                }

            </div>
        }

    </div>
</div>

@code {

    private void ToggleWatched(int id)
    {
        if (MovieState.WatchedMovieIds.Contains(id))
            MovieState.WatchedMovieIds.Remove(id);
        else
            MovieState.WatchedMovieIds.Add(id);
    }

    private void GoToReviews(int movieId)
    {
        NavManager.NavigateTo($"/reviews/{movieId}");
    }

    private void GoToMovie(int movieId)
    {
        NavManager.NavigateTo($"/movie/{movieId}");
    }
}