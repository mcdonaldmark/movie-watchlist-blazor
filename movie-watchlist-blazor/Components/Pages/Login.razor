@page "/login"
@using movie_watchlist_blazor.Services
@rendermode InteractiveServer
@inject AppState AppState
@inject NavigationManager NavManager

<div class="page-center">
    <div class="auth-card">

        <h2 style="border:none !important; box-shadow:none !important; margin-top:0;">
            Login
        </h2>

        <div class="mt-3">

            <input class="form-control mb-2" placeholder="Email" @bind="email" />
            <input class="form-control mb-3" placeholder="Password" type="password" @bind="password" />

            <button class="btn btn-primary w-100" @onclick="LoginUser">
                Login
            </button>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="text-danger mt-2">
                    @errorMessage
                </div>
            }

        </div>

        <p class="mt-3 mb-1 text-muted">
            Don't have an account? <a href="/register">Register</a>
        </p>

        <button type="button" class="btn btn-outline-light w-100 mt-1" @onclick="GoHome">
            Return to Home
        </button>

    </div>
</div>

@code {
    private string email = "";
    private string password = "";
    private string errorMessage = "";

    private void LoginUser()
    {
        errorMessage = "";

        // Validate input
        if (string.IsNullOrWhiteSpace(email) ||
            string.IsNullOrWhiteSpace(password))
        {
            errorMessage = "Email and password are required.";
            return;
        }

        // Find matching user
        var user = UserState.Users.FirstOrDefault(u =>
            u.Email.Equals(email, StringComparison.OrdinalIgnoreCase) &&
            u.Password == password);

        if (string.IsNullOrEmpty(user.Email))
        {
            errorMessage = "Invalid email or password. Please try again.";
            return;
        }

        // Successful login
        AppState.IsLoggedIn = true;
        AppState.CurrentUserName = user.Name;

        NavManager.NavigateTo("/dashboard");
    }

    private void GoHome()
    {
        NavManager.NavigateTo("/");
    }
}