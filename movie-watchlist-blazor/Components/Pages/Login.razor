@page "/login"
@rendermode InteractiveServer

@using System.Linq
@using movie_watchlist_blazor.Data
@using movie_watchlist_blazor.Services

@inject NavigationManager NavManager
@inject ApplicationDbContext Db
@inject AppState AppState

<div class="page-center">
    <div class="auth-card">

        <h2>Login</h2>

        <input class="form-control mb-2" placeholder="Email" @bind="email" />
        <input class="form-control mb-3" type="password" placeholder="Password" @bind="password" />

        <button class="btn btn-primary w-100" @onclick="LoginUser">
            Login
        </button>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="text-danger mt-2">@errorMessage</div>
        }

        <p class="mt-3 text-muted">
            Don't have an account?
            <a href="/register">Sign up!</a>
        </p>

        <p class="mt-2">
            <a href="/">← Return to Home Screen</a>
        </p>

    </div>
</div>

@code {
    private string email = "";
    private string password = "";
    private string errorMessage = "";

    private async Task LoginUser()
    {
        errorMessage = "";

        if (string.IsNullOrWhiteSpace(email) ||
            string.IsNullOrWhiteSpace(password))
        {
            errorMessage = "Email and password are required.";
            return;
        }

        var user = Db.Users.FirstOrDefault(u =>
            u.Email == email && u.Password == password);

        if (user == null)
        {
            errorMessage = "Invalid login.";
            return;
        }

        await AppState.SetUserAsync(user.Id, user.Name);
        NavManager.NavigateTo("/dashboard");
    }
}