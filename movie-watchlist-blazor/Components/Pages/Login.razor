@page "/login"
@using movie_watchlist_blazor.Services
@rendermode InteractiveServer
@inject AppState AppState
@inject NavigationManager NavManager

<div class="page-center">
    <div class="auth-card">

        <!-- FORCE REMOVE ANY TITLE BORDER -->
        <h2 style="border:none !important; box-shadow:none !important; margin-top:0;">
            Login
        </h2>

        <div class="mt-3">
            <input class="form-control mb-2" placeholder="Email" />
            <input class="form-control mb-3" placeholder="Password" type="password" />

            <button class="btn btn-primary w-100" @onclick="LoginUser">
                Login
            </button>
        </div>

        <p class="mt-3 mb-1 text-muted">
            Don't have an account? <a href="/register">Register</a>
        </p>

        <!-- HOME BUTTON -->
        <button type="button" class="btn btn-outline-light w-100 mt-1" @onclick="GoHome">
            Return to Home
        </button>
    </div>
</div>

@code {
    private void LoginUser()
    {
        AppState.IsLoggedIn = true;

        NavManager.NavigateTo("/dashboard");
    }

    private void GoHome()
    {
        Console.WriteLine("GoHome clicked");
        NavManager.NavigateTo("/");
    }
}