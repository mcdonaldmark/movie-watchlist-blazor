@page "/reviews/{MovieId:int}"
@using movie_watchlist_blazor.Models
@using movie_watchlist_blazor.Services
@inject IMovieService MovieService
@inject AppState AppState

@rendermode InteractiveServer

<div class="page-center">
    <div class="dashboard-wrapper w-100">

        <h3 class="mb-4 text-center">⭐ Reviews</h3>

        @if (movie == null)
        {
            <p class="text-center">Loading...</p>
        }
        else
        {

            <div class="card p-3 mb-4 shadow-sm">
                <h5>@movie.Title</h5>
                <p class="text-muted">@movie.Genre • @movie.Year</p>
            </div>

            <div class="card p-3 mb-4 shadow-sm">
                <h5>Add Review</h5>

                <textarea class="form-control mb-2" placeholder="Write review..." @bind="newReview.Comment"
                          @bind:event="oninput"></textarea>

                <div class="mb-2">
                    <div class="mb-1">Rating</div>
                    <div class="btn-group" role="group" aria-label="Rating selection">
                        @for (int i = 1; i <= 5; i++)
                        {
                            var starValue = i;
                            <button type="button"
                                    class="btn btn-sm @(newReview.Rating >= starValue ? "btn-warning" : "btn-outline-secondary")"
                                    @onclick="() => SetRating(starValue)">
                                @(newReview.Rating >= starValue ? "★" : "☆")
                            </button>
                        }
                    </div>
                    <div class="small text-muted mt-1">
                        Selected rating: <strong>@(newReview.Rating == 0 ? "None" : newReview.Rating.ToString())</strong>
                    </div>
                </div>

                <button type="button" class="btn btn-success w-100" @onclick="AddReview" disabled="@(!CanSubmitReview)">
                    Submit
                </button>
                @if (!CanSubmitReview)
                {
                    <div class="small text-danger mt-2">
                        Select a rating and write a comment before submitting.
                    </div>
                }
            </div>

            @if (!reviews.Any())
            {
                <p class="text-center">No reviews yet.</p>
            }
            else
            {
                @foreach (var r in reviews)
                {
                    <div class="card p-3 mb-3 shadow-sm">

                        @if (editingReviewId == r.Id)
                        {
                            <textarea class="form-control mb-2" @bind="editModel.Comment" @bind:event="oninput"></textarea>

                            <div class="mb-2">
                                <div class="mb-1">Rating</div>
                                <div class="btn-group" role="group" aria-label="Edit rating selection">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        var starValue = i;
                                        <button type="button"
                                                class="btn btn-sm @(editModel.Rating >= starValue ? "btn-warning" : "btn-outline-secondary")"
                                                @onclick="() => SetEditRating(starValue)">
                                            @(editModel.Rating >= starValue ? "★" : "☆")
                                        </button>
                                    }
                                </div>
                            </div>

                            <button class="btn btn-primary btn-sm me-2" @onclick="() => SaveEdit(r.Id)">
                                Save
                            </button>

                            <button class="btn btn-secondary btn-sm" @onclick="CancelEdit">
                                Cancel
                            </button>
                        }
                        else
                        {
                            <strong>
                                @r.UserName
                                @if (r.CreatedBy == AppState.CurrentUserId)
                                {
                                    <span class="text-muted"> (You)</span>
                                }
                            </strong>
                            <p>@r.Comment</p>
                            <div>⭐ @r.Rating</div>

                            <div class="mt-2 d-flex gap-2">

                                <button class="btn btn-warning btn-sm" @onclick="() => StartEdit(r)">
                                    Edit
                                </button>

                                <button class="btn btn-danger btn-sm" @onclick="() => Delete(r.Id)">
                                    Delete
                                </button>

                            </div>
                        }

                    </div>
                }
            }
        }

    </div>
</div>

@code {

    [Parameter] public int MovieId { get; set; }

    private MovieDto? movie;
    private List<ReviewDto> reviews = new();

    private ReviewDto newReview = new();

    private int? editingReviewId;
    private ReviewDto editModel = new();

    private bool CanSubmitReview => newReview.Rating >= 1 && newReview.Rating <= 5 &&
!string.IsNullOrWhiteSpace(newReview.Comment);

    private void SetRating(int rating)
    {
        newReview.Rating = rating;
        StateHasChanged();
    }

    private void SetEditRating(int rating)
    {
        editModel.Rating = rating;
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        var movies = await MovieService.GetMoviesAsync();
        movie = movies.FirstOrDefault(m => m.Id == MovieId);

        reviews = await MovieService.GetReviewsAsync(MovieId);
    }

    private async Task AddReview()
    {
        await MovieService.AddReviewAsync(MovieId, newReview);

        newReview = new ReviewDto();
        reviews = await MovieService.GetReviewsAsync(MovieId);
    }

    private void StartEdit(ReviewDto review)
    {
        editingReviewId = review.Id;
        editModel = new ReviewDto
        {
            Id = review.Id,
            Comment = review.Comment,
            Rating = review.Rating
        };
    }

    private async Task SaveEdit(int reviewId)
    {
        editModel.Id = reviewId;

        await MovieService.UpdateReviewAsync(MovieId, editModel);

        editingReviewId = null;
        reviews = await MovieService.GetReviewsAsync(MovieId);
    }

    private void CancelEdit()
    {
        editingReviewId = null;
    }

    private async Task Delete(int reviewId)
    {
        await MovieService.DeleteReviewAsync(MovieId, reviewId);
        reviews = await MovieService.GetReviewsAsync(MovieId);
    }
}