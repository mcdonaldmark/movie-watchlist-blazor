@page "/movie/{Id:int}"
@using movie_watchlist_blazor.Models
@using movie_watchlist_blazor.Services
@inject NavigationManager NavManager

<div class="page-center">
    <div class="dashboard-wrapper w-100">

        @if (movie == null)
        {
            <p class="text-center">Loading movie...</p>
        }
        else
        {
            <div class="card p-3 mb-3">

                <h3>@movie.Title</h3>
                <p class="text-muted">@movie.Genre • @movie.Year</p>

                @if (MovieState.WatchedMovieIds.Contains(movie.Id))
                {
                    <span class="badge bg-success">Watched</span>
                }
                else
                {
                    <span class="badge bg-warning text-dark">Not Watched</span>
                }

                <div class="mt-2">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <span>
                            @(i <= Math.Round(movie.AverageRating) ? "⭐" : "☆")
                        </span>
                    }
                </div>

                <div class="mt-3">
                    <button class="btn btn-success w-100" @onclick="ToggleWatched">
                        @(MovieState.WatchedMovieIds.Contains(movie.Id) ? "Unwatch" : "Mark Watched")
                    </button>
                </div>

            </div>

            <div class="card p-3 mb-3">
                <h5>🎥 Trailer</h5>

                <iframe width="100%" height="315" src="@TrailerUrl" frameborder="0" allowfullscreen>
                </iframe>
            </div>

        }

    </div>
</div>

@code {

    [Parameter] public int Id { get; set; }

    private MovieDto? movie;

    protected override void OnInitialized()
    {
        movie = MovieState.Movies.FirstOrDefault(m => m.Id == Id);
    }

    private void ToggleWatched()
    {
        if (movie == null) return;

        if (MovieState.WatchedMovieIds.Contains(movie.Id))
            MovieState.WatchedMovieIds.Remove(movie.Id);
        else
            MovieState.WatchedMovieIds.Add(movie.Id);
    }

    private string TrailerUrl =>
        movie switch
        {
            { Id: 1 } => "https://www.youtube.com/embed/YoHD9XEInc0", // Inception
            { Id: 2 } => "https://www.youtube.com/embed/zSWdZVtXT7E", // Interstellar
            { Id: 3 } => "https://www.youtube.com/embed/EXeTwQWrcwY", // Dark Knight
            { Id: 4 } => "https://www.youtube.com/embed/7G2YAtFeVJo", // Toy Story
            _ => "https://www.youtube.com/embed/dQw4w9WgXcQ"
        };
}