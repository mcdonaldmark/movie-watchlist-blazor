@page
@model movie_watchlist_blazor.Areas.Identity.Pages.Account.LoginModel

<h3>Login</h3>

<form method="post">
    <div>
        <label>Email</label>
        <input asp-for="Input.Email" />
    </div>

    <div>
        <label>Password</label>
        <input asp-for="Input.Password" type="password" />
    </div>

    <button type="submit">Login</button>
</form>

@if (!ModelState.IsValid)
{
    <p style="color:red">Invalid login attempt.</p>
}
